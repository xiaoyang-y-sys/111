<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>电商商品详情页 - 高级版</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        body {
            background-color: #f5f5f5;
            padding: 20px;
        }

        .product-detail {
            max-width: 1200px;
            margin: 0 auto;
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
        }

        /* 桌面端布局 */
        @media (min-width: 992px) {
            .product-detail {
                display: flex;
                gap: 60px;
                padding: 48px;
            }
            .product-gallery {
                flex: 0 0 50%;
            }
            .product-info {
                flex: 1;
            }
        }

        /* 平板端布局 */
        @media (min-width: 768px) and (max-width: 991px) {
            .product-detail {
                padding: 32px;
            }
            .product-gallery {
                margin-bottom: 32px;
            }
        }

        /* 移动端布局 */
        @media (max-width: 767px) {
            .product-detail {
                padding: 20px;
            }
            .product-gallery {
                margin-bottom: 24px;
            }
        }

        /* 商品图库 */
        .product-gallery {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .main-carousel-wrapper {
            position: relative;
            overflow: hidden;
            border-radius: 12px;
            background: #fafafa;
        }

        .main-carousel {
            display: flex;
            transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        .main-carousel-item {
            flex: 0 0 100%;
            cursor: zoom-in;
        }

        .main-carousel-item img {
            width: 100%;
            height: auto;
            display: block;
            object-fit: cover;
            aspect-ratio: 1 / 1;
        }

        /* 轮播控制按钮 */
        .carousel-nav-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 44px;
            height: 44px;
            background: rgba(0, 0, 0, 0.4);
            color: #fff;
            border: none;
            border-radius: 50%;
            cursor: pointer;
            font-size: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
            z-index: 10;
        }

        .carousel-nav-btn:hover {
            background: rgba(0, 0, 0, 0.6);
        }

        .carousel-nav-btn.prev {
            left: 16px;
        }

        .carousel-nav-btn.next {
            right: 16px;
        }

        /* 指示器 */
        .main-indicators {
            position: absolute;
            bottom: 16px;
            left: 0;
            right: 0;
            display: flex;
            justify-content: center;
            gap: 8px;
            z-index: 10;
        }

        .main-indicator {
            width: 8px;
            height: 8px;
            border-radius: 4px;
            background: rgba(255, 255, 255, 0.5);
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .main-indicator.active {
            background: #fff;
            width: 24px;
        }

        /* 缩略图 */
        .thumbnails {
            display: flex;
            gap: 12px;
            overflow-x: auto;
            padding-bottom: 8px;
            scrollbar-width: thin;
        }

        .thumbnail-item {
            flex: 0 0 80px;
            height: 80px;
            border-radius: 8px;
            overflow: hidden;
            cursor: pointer;
            border: 2px solid transparent;
            transition: border-color 0.2s ease;
        }

        .thumbnail-item.active {
            border-color: #ff4d4f;
        }

        .thumbnail-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* 商品信息区 */
        .product-info {
            color: #333;
        }

        .product-title {
            font-size: 28px;
            font-weight: 600;
            line-height: 1.3;
            margin-bottom: 16px;
        }

        .product-subtitle {
            font-size: 14px;
            color: #999;
            margin-bottom: 20px;
        }

        .product-price-section {
            background: #fafafa;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 24px;
        }

        .price-label {
            font-size: 14px;
            color: #666;
            margin-bottom: 4px;
        }

        .product-price {
            font-size: 36px;
            color: #ff4d4f;
            font-weight: 700;
        }

        .original-price {
            font-size: 16px;
            color: #999;
            text-decoration: line-through;
            margin-left: 12px;
        }

        .product-meta {
            display: flex;
            gap: 24px;
            margin-bottom: 24px;
            font-size: 14px;
            color: #666;
        }

        .product-meta-item {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* 规格选择 */
        .spec-section {
            margin-bottom: 24px;
        }

        .spec-title {
            font-size: 16px;
            font-weight: 500;
            margin-bottom: 12px;
        }

        .spec-options {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .spec-option {
            padding: 10px 16px;
            border: 1px solid #ddd;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-size: 14px;
        }

        .spec-option:hover {
            border-color: #ff4d4f;
        }

        .spec-option.active {
            border-color: #ff4d4f;
            background: #fff5f5;
            color: #ff4d4f;
        }

